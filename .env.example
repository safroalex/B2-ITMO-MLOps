# Скопируй этот файл в .env и заполни своими credentials
# cp .env.example .env
#
# Credentials можно получить в Web UI:
#   http://localhost:8080 → Settings → Workspace → Create new credentials

# --- ClearML API credentials (нужны для Serving) ---
CLEARML_API_ACCESS_KEY=your_access_key_here
CLEARML_API_SECRET_KEY=your_secret_key_here
